# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AABBccDDeeFFggHH-IiJjKkLl

# Channel IDs required for subscription gate (comma-separated, or leave empty)
REQUIRED_CHANNEL_IDS=-1001234567890,-1009876543210

# Bot owner's Telegram user ID (can always access bot regardless of subscription)
OWNER_ID=123456789

# ── Telethon API Credentials ───────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef1234567890abcdef1234567890

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here=

# ── Database ──────────────────────────────────────────────────────────────────
# Accepts any of these formats (DATABASE_SYNC_URL is auto-derived):
#   postgresql://user:pass@host:5432/db       ← Railway format
#   postgresql+asyncpg://user:pass@host/db    ← explicit asyncpg
DATABASE_URL=postgresql://bot:bot_password@postgres:5432/bot_db
# DATABASE_SYNC_URL is optional — auto-derived from DATABASE_URL

# For Docker Compose postgres service:
POSTGRES_DB=bot_db
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SESSION_HEALTH_CHECK_INTERVAL=1800
