# ═══════════════════════════════════════════════════════════════════════════
#  .env.example — copy to .env for local Docker Compose
#
#  Railway deployment: set these in Railway UI → Variables.
#  Variables marked [Railway: auto] are injected automatically by Railway
#  plugins — do NOT set them manually there.
# ═══════════════════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AABBccDDeeFFggHH-IiJjKkLl

# Channel IDs required for subscription gate (comma-separated, or leave empty)
REQUIRED_CHANNEL_IDS=-1001234567890,-1009876543210

# Bot owner's Telegram user ID (always has access regardless of subscription)
OWNER_ID=123456789

# ── Telethon API Credentials (OPTIONAL) ──────────────────────────────────────
# opentele2 uses official Telegram iOS API credentials internally — these fields
# are no longer required and can be left unset in Railway.
# TELETHON_API_ID=12345678
# TELETHON_API_HASH=abcdef1234567890abcdef1234567890

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here=

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose): keep as-is.
# RAILWAY: add the PostgreSQL plugin → DATABASE_URL is injected automatically.
#          Do NOT copy this line to Railway variables.
DATABASE_URL=postgresql://bot:bot_password@postgres:5432/bot_db

# DATABASE_SYNC_URL is optional — auto-derived from DATABASE_URL at startup.
# DATABASE_SYNC_URL=

# Only needed for local Docker Compose postgres service:
POSTGRES_DB=bot_db
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password

# ── Redis ─────────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose): keep as-is.
# RAILWAY: add the Redis plugin (separate environment on free plan) →
#          copy the REDIS_URL value shown in Railway into your service variables.
REDIS_URL=redis://redis:6379/0

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SESSION_HEALTH_CHECK_INTERVAL=1800
